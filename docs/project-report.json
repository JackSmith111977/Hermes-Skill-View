  "architecture": {
    "layers": [
      {
        "name": "Layer 3 — 接口层 Interface",
        "modules": [
          "CLI (sra)",
          "HTTP API (:8536)",
          "Unix Socket (~/.sra/srad.sock)"
        ],
        "direction": "delegate"
      },
      {
        "name": "Layer 2 — 业务逻辑层 Service",
        "modules": [
          "SRaDDaemon (daemon.py)",
          "SkillAdvisor (advisor.py)",
          "SkillMatcher (matcher.py)",
          "SkillIndexer (indexer.py)",
          "ForceLevelManager (force.py)",
          "SceneMemory (memory.py)",
          "Synonyms (synonyms.py)"
        ],
        "direction": "read-write"
      },
      {
        "name": "Layer 1 — 数据层 Data",
        "modules": [
          "~/.hermes/skills/",
          "~/.sra/data/",
          "~/.sra/config.json"
        ],
        "direction": null
      }
    ],
    "module_table": [
      {
        "module": "SkillAdvisor",
        "file": "advisor.py",
        "desc": "推荐引擎主入口，Facade 封装",
        "methods": [
          "recommend()",
          "recheck()",
          "record_view/use/skip()",
          "analyze_coverage()",
          "build_contract()"
        ]
      },
      {
        "module": "SRaDDaemon",
        "file": "runtime/daemon.py",
        "desc": "守护进程，HTTP + Socket 双协议",
        "methods": [
          "start()",
          "stop()",
          "_handle_request()",
          "get_stats()"
        ]
      },
      {
        "module": "SkillMatcher",
        "file": "matcher.py",
        "desc": "四维匹配引擎（词法/语义/场景/类别）",
        "methods": [
          "score()"
        ]
      },
      {
        "module": "SkillIndexer",
        "file": "indexer.py",
        "desc": "技能扫描、索引构建、关键词提取",
        "methods": [
          "build()",
          "load_or_build()",
          "get_skills()",
          "extract_keywords()"
        ]
      },
      {
        "module": "SceneMemory",
        "file": "memory.py",
        "desc": "场景记忆 + 技能轨迹追踪 + 遵循率统计",
        "methods": [
          "record_view/use/skip()",
          "get_compliance_stats()"
        ]
      },
      {
        "module": "ForceLevelManager",
        "file": "runtime/force.py",
        "desc": "力度等级引擎",
        "methods": [
          "get_level()",
          "set_level()",
          "is_injection_point_active()"
        ],
        "new_in": "v1.3.0"
      },
      {
        "module": "Validate",
        "file": "runtime/endpoints/validate.py",
        "desc": "工具调用前技能校验",
        "methods": [
          "handle_validate()"
        ]
      },
      {
        "module": "SkillMap",
        "file": "skill_map.py",
        "desc": "文件扩展名→技能映射注册表",
        "methods": [
          "get_required_skills()"
        ]
      },
      {
        "module": "CLI",
        "file": "cli.py",
        "desc": "命令行接口 + 降级策略",
        "methods": [
          "cmd_*() + _socket_request()"
        ]
      },
      {
        "module": "Lock",
        "file": "runtime/lock.py",
        "desc": "OS 级文件锁（fcntl.flock 单例保障）",
        "methods": [
          "acquire_lock()"
        ]
      },
      {
        "module": "sra-guard Plugin",
        "file": "plugins/sra-guard/__init__.py",
        "desc": "Hermes 插件入口 + hook 注册",
        "methods": [
          "register()",
          "_on_pre_llm_call()",
          "_on_pre_tool_call()"
        ]
      },
      {
        "module": "SraClient",
        "file": "plugins/sra-guard/client.py",
        "desc": "SRA Daemon 通信客户端",
        "methods": [
          "recommend()",
          "validate()"
        ]
      },
      {
        "module": "ContextFormatter",
        "file": "plugins/sra-guard/formatter.py",
        "desc": "SRA 上下文格式化",
        "methods": [
          "format_context()",
          "format_skills_block()"
        ]
      }
    ]
  },
