@@ -1113,3 +1113,65 @@ def build_context_files_prompt(cwd: Optional[str] = None, skip_soul: bool = Fals
     if not sections:
         return ""
     return "# Project Context\n\nThe following project context files have been loaded and should be followed:\n\n" + "\n".join(sections)
+
+
+def build_sra_context_prompt() -> str:
+    """Query SRA Daemon for skill recommendations and return RAG context.
+
+    Called during system prompt assembly.  If SRA Daemon is not running
+    or unreachable, returns empty string silently — no error propagation.
+    The result is capped at 2000 chars to avoid bloating the prompt.
+    """
+    import urllib.request
+    import json as _json
+
+    sra_url = os.environ.get("SRA_PROXY_URL", "http://127.0.0.1:8536")
+    health_url = f"{sra_url}/health"
+    recommend_url = f"{sra_url}/recommend"
+
+    try:
+        # Quick health check first
+        req = urllib.request.Request(health_url, method="GET")
+        with urllib.request.urlopen(req, timeout=1.0) as resp:
+            if resp.status != 200:
+                return ""
+    except Exception:
+        return ""
+
+    try:
+        payload = _json.dumps({"message": "system_prompt_build"}).encode("utf-8")
+        req = urllib.request.Request(
+            recommend_url,
+            data=payload,
+            headers={"Content-Type": "application/json"},
+            method="POST",
+        )
+        with urllib.request.urlopen(req, timeout=2.0) as resp:
+            data = _json.loads(resp.read().decode("utf-8"))
+
+        rag_context = data.get("rag_context", "")
+        should_auto_load = data.get("should_auto_load", False)
+        top_skill = data.get("top_skill")
+
+        if not rag_context:
+            return ""
+
+        # Build the SRA section for the system prompt
+        lines = ["# SRA Skill Recommendations",
+                 "",
+                 "The Skill Runtime Advisor has analyzed the user's request and recommends:"]
+        lines.append(rag_context)
+
+        if should_auto_load and top_skill:
+            lines.append(f"\n⚡ Auto-load recommended: `{top_skill}` — use skill_view('{top_skill}') if needed.")
+
+        result = "\n".join(lines)
+
+        # Cap at 2000 chars
+        if len(result) > 2000:
+            result = result[:1997] + "..."
+
+        return result
+
+    except Exception:
+        return ""
